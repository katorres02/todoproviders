# SQLite for development. For production use PostgreSQL (Supabase/Neon), e.g.:
# DATABASE_URL="postgresql://user:password@host:5432/wedding?schema=public"
DATABASE_URL="file:./dev.db"

# Secret used to sign JWT access tokens. Use a long random string in production.
JWT_SECRET="change-me-in-production"

# Port for the Express API
PORT=4000

# Allowed CORS origin (frontend URL)
CORS_ORIGIN="http://localhost:5173"

# Wedding date exposed via /api/dashboard (ISO format)
WEDDING_DATE="2026-12-12"
