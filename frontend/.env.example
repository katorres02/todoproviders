# Base URL of the backend API. Leave empty to use the Vite dev proxy (/api -> localhost:4000).
# In production (Vercel) set it to your Render backend URL, e.g. https://wedding-api.onrender.com
VITE_API_URL=

# Wedding date shown in the countdown (fallback if the API does not provide one)
VITE_WEDDING_DATE=2026-12-12
